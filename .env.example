# Public Vite settings (safe to include in the browser bundle)
VITE_EXTERNAL_PUSH_ENABLED=false
VITE_ONESIGNAL_APP_ID=replace_with_public_onesignal_app_id
VITE_SUPABASE_URL=https://PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=replace_with_public_anon_or_publishable_key

# Server-only Vercel Function settings (never prefix these with VITE_)
ONESIGNAL_APP_ID=replace_with_onesignal_app_id
ONESIGNAL_API_KEY=replace_with_server_api_key
PUSH_SIGNING_SECRET=replace_with_at_least_32_random_characters
PUSH_ALLOWED_ORIGIN=https://replace-with-production-origin.example
EXTERNAL_PUSH_ENABLED=false
# Base project URL only; do not append /rest/v1 (the Supabase client adds it).
SUPABASE_URL=https://PROJECT_ID.supabase.co
SUPABASE_SECRET_KEY=replace_with_server_secret_or_service_role_key
CRON_SECRET=replace_with_random_cron_secret
